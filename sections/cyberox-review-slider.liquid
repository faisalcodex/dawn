{% comment %} Cyberox Review Slider {% endcomment %}
<section class="cx-review-slider" id="cx-review-slider-{{ section.id }}" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cx-container">
    {% if section.settings.heading != blank %}
    <div class="cx-section-header" style="text-align:{{ section.settings.heading_align }};">
      <h2 style="color:{{ section.settings.heading_color }};font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
      <p style="color:{{ section.settings.subheading_color }};">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    {% endif %}
    <div class="cx-reviews-track-wrapper">
      <div class="cx-reviews-track" id="cxReviewTrack-{{ section.id }}">
        {% for block in section.blocks %}
        {% if block.type == 'review' %}
        <div class="cx-review-card" {{ block.shopify_attributes }} style="background:{{ section.settings.card_bg }};border-radius:{{ section.settings.card_radius }}px;">
          <div class="cx-review-stars">
            {% assign rating = block.settings.rating %}
            {% for i in (1..5) %}
              {% if i <= rating %}
                <span style="color:{{ section.settings.star_color }};">&#9733;</span>
              {% else %}
                <span style="color:#ddd;">&#9733;</span>
              {% endif %}
            {% endfor %}
          </div>
          {% if block.settings.review_text != blank %}
          <p class="cx-review-text" style="color:{{ section.settings.text_color }};">"{{ block.settings.review_text }}"</p>
          {% endif %}
          <div class="cx-review-author">
            {% if block.settings.author_image != blank %}
            <img src="{{ block.settings.author_image | img_url: '80x80', crop: 'center' }}" alt="{{ block.settings.author_name }}" class="cx-review-avatar" loading="lazy">
            {% else %}
            <div class="cx-review-avatar-placeholder" style="background:{{ section.settings.star_color }};color:#fff;">{{ block.settings.author_name | slice: 0 | upcase }}</div>
            {% endif %}
            <div>
              <strong style="color:{{ section.settings.heading_color }};">{{ block.settings.author_name }}</strong>
              {% if block.settings.author_title != blank %}
              <span style="color:{{ section.settings.subheading_color }};">{{ block.settings.author_title }}</span>
              {% endif %}
            </div>
          </div>
        </div>
        {% endif %}
        {% endfor %}
      </div>
    </div>
    {% if section.settings.show_dots %}
    <div class="cx-review-dots" id="cxReviewDots-{{ section.id }}"></div>
    {% endif %}
    {% if section.settings.show_arrows %}
    <div class="cx-review-arrows">
      <button class="cx-arr cx-arr--prev" data-target="cxReviewTrack-{{ section.id }}" aria-label="Previous">&#8592;</button>
      <button class="cx-arr cx-arr--next" data-target="cxReviewTrack-{{ section.id }}" aria-label="Next">&#8594;</button>
    </div>
    {% endif %}
  </div>
</section>

<style>
#cx-review-slider-{{ section.id }} .cx-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
#cx-review-slider-{{ section.id }} .cx-section-header { margin-bottom: 40px; }
#cx-review-slider-{{ section.id }} .cx-section-header h2 { margin: 0 0 10px; line-height: 1.2; }
#cx-review-slider-{{ section.id }} .cx-section-header p { margin: 0; opacity: 0.8; }
#cx-review-slider-{{ section.id }} .cx-reviews-track-wrapper { overflow: hidden; }
#cx-review-slider-{{ section.id }} .cx-reviews-track { display: flex; gap: {{ section.settings.card_gap }}px; transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94); will-change: transform; }
#cx-review-slider-{{ section.id }} .cx-review-card { flex: 0 0 calc((100% - {{ section.settings.card_gap | times: 2 }}px) / {{ section.settings.cards_visible }}); padding: 28px; box-shadow: 0 2px 16px rgba(0,0,0,0.08); box-sizing: border-box; }
#cx-review-slider-{{ section.id }} .cx-review-stars { font-size: 20px; margin-bottom: 14px; }
#cx-review-slider-{{ section.id }} .cx-review-text { font-size: 15px; line-height: 1.7; margin: 0 0 20px; }
#cx-review-slider-{{ section.id }} .cx-review-author { display: flex; align-items: center; gap: 12px; }
#cx-review-slider-{{ section.id }} .cx-review-avatar { width: 46px; height: 46px; border-radius: 50%; object-fit: cover; }
#cx-review-slider-{{ section.id }} .cx-review-avatar-placeholder { width: 46px; height: 46px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; flex-shrink: 0; }
#cx-review-slider-{{ section.id }} .cx-review-author strong { display: block; font-size: 15px; }
#cx-review-slider-{{ section.id }} .cx-review-author span { font-size: 13px; opacity: 0.7; }
#cx-review-slider-{{ section.id }} .cx-review-dots { display: flex; justify-content: center; gap: 8px; margin-top: 28px; }
#cx-review-slider-{{ section.id }} .cx-review-dots span { width: 10px; height: 10px; border-radius: 50%; background: #ddd; cursor: pointer; transition: background 0.3s; }
#cx-review-slider-{{ section.id }} .cx-review-dots span.active { background: {{ section.settings.star_color }}; }
#cx-review-slider-{{ section.id }} .cx-review-arrows { display: flex; justify-content: center; gap: 12px; margin-top: 20px; }
#cx-review-slider-{{ section.id }} .cx-arr { width: 44px; height: 44px; border-radius: 50%; border: 2px solid {{ section.settings.star_color }}; background: transparent; color: {{ section.settings.star_color }}; font-size: 18px; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; }
#cx-review-slider-{{ section.id }} .cx-arr:hover { background: {{ section.settings.star_color }}; color: #fff; }
@media(max-width:768px){
  #cx-review-slider-{{ section.id }} .cx-review-card { flex: 0 0 calc(100% - {{ section.settings.card_gap }}px); }
}
</style>

<script>
(function(){
  var trackId = 'cxReviewTrack-{{ section.id }}';
  var dotsId  = 'cxReviewDots-{{ section.id }}';
  var track   = document.getElementById(trackId);
  if (!track) return;
  var cards   = track.querySelectorAll('.cx-review-card');
  var total   = cards.length;
  var visible = {{ section.settings.cards_visible }};
  var current = 0;
  var autoplay = {{ section.settings.autoplay }};
  var speed   = {{ section.settings.autoplay_speed }};
  var timer;

  function isMobile(){ return window.innerWidth <= 768; }
  function getVisible(){ return isMobile() ? 1 : visible; }

  function goTo(idx){
    var vis = getVisible();
    var max = Math.max(0, total - vis);
    current = Math.min(Math.max(idx, 0), max);
    var cardW = track.parentElement.offsetWidth / vis;
    track.style.transform = 'translateX(-' + (current * (cardW + {{ section.settings.card_gap }})) + 'px)';
    updateDots();
  }

  function updateDots(){
    var dots = document.querySelectorAll('#' + dotsId + ' span');
    dots.forEach(function(d,i){ d.classList.toggle('active', i === current); });
  }

  // Build dots
  var dotsEl = document.getElementById(dotsId);
  if (dotsEl){
    var vis = getVisible();
    var pages = Math.max(1, total - vis + 1);
    for(var i=0;i<pages;i++){
      var dot = document.createElement('span');
      if(i===0) dot.classList.add('active');
      (function(idx){ dot.addEventListener('click', function(){ goTo(idx); resetAuto(); }); })(i);
      dotsEl.appendChild(dot);
    }
  }

  // Arrows
  document.querySelectorAll('.cx-arr[data-target="' + trackId + '"]').forEach(function(btn){
    btn.addEventListener('click', function(){
      if(btn.classList.contains('cx-arr--prev')) goTo(current - 1);
      else goTo(current + 1);
      resetAuto();
    });
  });

  // Autoplay
  function startAuto(){ if(autoplay){ timer = setInterval(function(){ goTo(current + 1 > total - getVisible() ? 0 : current + 1); }, speed); } }
  function resetAuto(){ clearInterval(timer); startAuto(); }
  startAuto();

  // Touch swipe
  var startX = 0;
  track.addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; }, {passive:true});
  track.addEventListener('touchend', function(e){
    var diff = startX - e.changedTouches[0].clientX;
    if(Math.abs(diff) > 50){ goTo(diff > 0 ? current + 1 : current - 1); resetAuto(); }
  }, {passive:true});

  window.addEventListener('resize', function(){ goTo(current); });
})();
</script>

{% schema %}
{
  "name": "Cyberox Review Slider",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "select", "id": "heading_align", "label": "Heading Align", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range", "id": "heading_size", "label": "Heading Size (px)", "min": 20, "max": 60, "step": 2, "default": 36 },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Trusted by thousands of happy customers" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f9f9f9" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1a1a1a" },
    { "type": "color", "id": "subheading_color", "label": "Subheading / Meta Color", "default": "#666666" },
    { "type": "color", "id": "text_color", "label": "Review Text Color", "default": "#444444" },
    { "type": "color", "id": "star_color", "label": "Star & Accent Color", "default": "#f5a623" },
    { "type": "range", "id": "card_radius", "label": "Card Border Radius (px)", "min": 0, "max": 30, "step": 2, "default": 12 },
    { "type": "range", "id": "card_gap", "label": "Gap Between Cards (px)", "min": 10, "max": 40, "step": 2, "default": 20 },
    { "type": "range", "id": "cards_visible", "label": "Cards Visible (Desktop)", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "padding_top", "label": "Padding Top (px)", "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom (px)", "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "checkbox", "id": "show_dots", "label": "Show Dots", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show Arrows", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay Speed (ms)", "min": 2000, "max": 8000, "step": 500, "default": 4000 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Star Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review Text", "default": "This product completely exceeded my expectations. Absolutely love it!" },
        { "type": "text", "id": "author_name", "label": "Author Name", "default": "Sarah J." },
        { "type": "text", "id": "author_title", "label": "Author Title / Location", "default": "Verified Buyer" },
        { "type": "image_picker", "id": "author_image", "label": "Author Photo (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cyberox Review Slider",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "review_text": "Absolutely love this product! Quality is top notch and shipping was super fast.", "author_name": "Emily R.", "author_title": "Verified Buyer" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Best purchase I have made this year. Will definitely be ordering again soon!", "author_name": "James K.", "author_title": "Loyal Customer" } },
        { "type": "review", "settings": { "rating": 4, "review_text": "Great value for money. The product looks even better in person than in photos.", "author_name": "Maria L.", "author_title": "Verified Buyer" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Customer service was amazing and the product arrived ahead of schedule!", "author_name": "Tom B.", "author_title": "Repeat Customer" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "I was skeptical at first but this product truly delivered. Highly recommend!", "author_name": "Aisha N.", "author_title": "Verified Buyer" } }
      ]
    }
  ]
}
